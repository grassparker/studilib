{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "StudiLib",
  "version": "0.1.0",
  "identifier": "com.studilib.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "studilib",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/Character.png"
    ]
  }
}
